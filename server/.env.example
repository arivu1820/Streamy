# =============================================================================
# Streamy BACKEND (NestJS) — environment reference.
#
# You normally do NOT need this file for Docker Compose (compose builds these
# values for you). Use it when running the server directly on the host
# (`npm run dev -w streamy-server`) against Dockerized Postgres/Redis, and as the
# canonical list of what to set on Render in production.
#
# Copy to server/.env for host-direct dev:  cp server/.env.example server/.env
# =============================================================================

NODE_ENV=development
# Render injects PORT in production. Locally the app defaults to 4000.
PORT=4000

# --- Database (Prisma / Postgres) -------------------------------------------
# Host-direct dev points at the Dockerized Postgres published on localhost.
DATABASE_URL=postgresql://streamy:streamy@localhost:5432/streamy?schema=public
# Direct (unpooled) URL used by `prisma migrate`. Same as DATABASE_URL locally.
DIRECT_URL=postgresql://streamy:streamy@localhost:5432/streamy?schema=public

# --- Auth -------------------------------------------------------------------
JWT_SECRET=dev-streamy-secret-change-in-prod   # MUST be a strong random value in prod
GOOGLE_CLIENT_ID=                              # blank => dev login only

# --- CORS -------------------------------------------------------------------
WEB_ORIGIN=http://localhost:3000               # comma-separated list allowed

# --- Redis (Socket.IO adapter) ----------------------------------------------
# Local: the Dockerized redis published on localhost. Prod: Upstash rediss:// URL.
REDIS_URL=redis://localhost:6379

# --- Object storage ---------------------------------------------------------
# local => videos on disk under UPLOAD_DIR. r2 => Cloudflare R2 (set R2_* below).
STORAGE_DRIVER=local
UPLOAD_DIR=./server/storage
# R2 (only needed when STORAGE_DRIVER=r2):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=streamy-videos
# R2_PUBLIC_BASE_URL=         # optional public/CDN base; else presigned URLs are used
# R2_URL_TTL_SECONDS=3600     # presigned URL lifetime
