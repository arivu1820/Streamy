# Streamy server config.
# NOTE: SQLite has been retired. These values are for running the backend
# DIRECTLY ON THE HOST (npm run dev) against the Dockerized Postgres/Redis,
# which publish to localhost. When the server runs INSIDE Docker Compose, the
# host is overridden to the `postgres`/`redis` service names (see docker-compose.yml).
DATABASE_URL="postgresql://streamy:streamy@localhost:5432/streamy?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="dev-streamy-secret-change-in-prod"
PORT=4000
WEB_ORIGIN="http://localhost:3000"
UPLOAD_DIR="./storage"

# Optional: real Google Sign-In. Leave blank to use dev login only.
GOOGLE_CLIENT_ID=""
