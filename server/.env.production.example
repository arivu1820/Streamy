# =============================================================================
# Streamy BACKEND — PRODUCTION (Render) reference.
# Set these in Render → service → Environment (or let render.yaml prompt you).
# NEVER commit real values.
# =============================================================================

NODE_ENV=production
# PORT — do NOT set; Render injects it and the app binds 0.0.0.0:$PORT.

# --- Neon Postgres ----------------------------------------------------------
# POOLED connection (host contains "-pooler"). Note ?sslmode=require is mandatory.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/streamy?sslmode=require
# DIRECT connection (NO "-pooler") — used by `prisma migrate deploy` at boot.
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/streamy?sslmode=require

# --- Auth -------------------------------------------------------------------
JWT_SECRET=replace-with-64-char-random-string
GOOGLE_CLIENT_ID=

# --- CORS / frontend --------------------------------------------------------
# Your Vercel URL (and any custom domain). Comma-separated, no trailing slash.
WEB_ORIGIN=https://streamy.vercel.app

# --- Upstash Redis ----------------------------------------------------------
# Use the rediss:// (TLS) endpoint from the Upstash console.
REDIS_URL=rediss://default:PASSWORD@apt-xxxx-12345.upstash.io:6379

# --- Cloudflare R2 ----------------------------------------------------------
STORAGE_DRIVER=r2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=streamy-videos
# R2_PUBLIC_BASE_URL=https://cdn.yourdomain.com   # optional
# R2_URL_TTL_SECONDS=3600
