# =============================================================================
# Streamy — root environment for Docker Compose.
# Copy to `.env` (same folder as docker-compose.yml):  cp .env.example .env
# Compose auto-loads `.env`. Every value below also has a safe default baked
# into docker-compose.yml, so `docker compose up` works even without this file.
# =============================================================================

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=streamy
POSTGRES_PASSWORD=streamy           # CHANGE for any shared/prod environment
POSTGRES_DB=streamy
POSTGRES_PORT=5432                  # host port for psql / Prisma Studio / GUIs

# --- Redis ------------------------------------------------------------------
REDIS_PORT=6379

# --- Backend (server) -------------------------------------------------------
JWT_SECRET=dev-streamy-secret-change-in-prod   # MUST change outside local dev
WEB_ORIGIN=http://localhost:3000               # CORS allow-list (comma-separated ok)
GOOGLE_CLIENT_ID=                              # blank => dev login only

# --- Frontend (web) ---------------------------------------------------------
# Browser-side base URL for the API. In local Docker this is the host-published
# backend port. In production set it to your public API origin (e.g. https://api.streamy.app).
NEXT_PUBLIC_API_BASE=http://localhost:4000

# NOTE: The backend's DATABASE_URL and REDIS_URL are constructed inside
# docker-compose.yml from the values above and point at the `postgres` / `redis`
# service names — you do not set them here.
