# =============================================================================
# Streamy frontend — PRODUCTION (Vercel).
# Do NOT commit real values. Set these in:
#   Vercel → Project → Settings → Environment Variables → Production
# NEXT_PUBLIC_* values are inlined at BUILD time, so changing them requires a
# redeploy (not just a restart).
# =============================================================================

# Your public Render backend origin (https). Used for REST AND WebSocket
# (wss is derived from this). Must be the real Render URL or your custom domain.
NEXT_PUBLIC_API_BASE=https://streamy-api.onrender.com

# Optional TURN relay (see comments in .env.example).
# NEXT_PUBLIC_TURN_URL=
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=
