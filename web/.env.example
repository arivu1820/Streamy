# =============================================================================
# Streamy frontend (Next.js) — LOCAL development.
# Copy to web/.env.local:  cp web/.env.example web/.env.local
#
# ONLY variables prefixed NEXT_PUBLIC_ are exposed to the browser. Never put a
# secret here — anything in this file ships in the client bundle.
# =============================================================================

# Base origin of the backend API (no trailing slash). The app appends /api/v1
# for REST and /rt for the Socket.IO namespace.
NEXT_PUBLIC_API_BASE=http://localhost:4000

# Optional TURN relay for voice chat behind strict NATs/firewalls.
# Free Google STUN is built in; TURN is only needed if peers can't connect.
# NEXT_PUBLIC_TURN_URL=turn:your-turn-host:3478
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=
